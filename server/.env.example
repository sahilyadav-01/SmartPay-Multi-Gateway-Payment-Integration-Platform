# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
MONGODB_URI=mongodb://localhost:27017/smartpay

# JWT configuration
JWT_SECRET=super_secret_jwt_sign_key_smartpay_2026
JWT_REFRESH_SECRET=super_secret_refresh_jwt_sign_key_smartpay_2026
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Payment Gateways configuration (sandbox/test credentials)
RAZORPAY_KEY_ID=rzp_test_key_placeholder
RAZORPAY_KEY_SECRET=rzp_test_secret_placeholder
RAZORPAY_WEBHOOK_SECRET=rzp_webhook_secret_placeholder

STRIPE_PUBLISHABLE_KEY=pk_test_stripe_placeholder
STRIPE_SECRET_KEY=sk_test_stripe_placeholder
STRIPE_WEBHOOK_SECRET=whsec_stripe_placeholder

PAYPAL_CLIENT_ID=paypal_client_id_placeholder
PAYPAL_CLIENT_SECRET=paypal_client_secret_placeholder
PAYPAL_MODE=sandbox

# Notification configuration (Email)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=ethereal_username
SMTP_PASS=ethereal_password
FROM_EMAIL=noreply@smartpay.io
